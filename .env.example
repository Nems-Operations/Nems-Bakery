# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=""

# PayFast Integration Credentials
VITE_PAYFAST_MERCHANT_ID=""
VITE_PAYFAST_MERCHANT_KEY=""

# Gmail SMTP Email Automation Credentials
GMAIL_APP_PASSWORD=""

# Firebase Web App client configuration
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""

# Static Hosting & External API Configuration (GitHub Pages / Firebase Functions)
# VITE_API_URL: Absolute external URL of your backend or Firebase Cloud Functions if used (e.g. https://us-central1-proj.cloudfunctions.net)
VITE_API_URL=""
# VITE_FIREBASE_FUNCTIONS_URL: Alternative configuration parameter for direct cloud function endpoint URL
VITE_FIREBASE_FUNCTIONS_URL=""
# VITE_FORCE_CLIENT_CHECKOUT: Set to "true" to force pure frontend direct compilation of PayFast fields on the client
VITE_FORCE_CLIENT_CHECKOUT=""
# VITE_WEBHOOK_URL: Set to the specific absolute URL of your webhook notification handler (e.g. backend api notify endpoint)
VITE_WEBHOOK_URL=""
